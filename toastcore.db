{?text = {}, ?prompt = "[Wpisz linie tekstu; uzyj `.', by zakonczyc.]", ?commandchar = this:get_opt("cmd_char", player), ?verb = 0, ?extra = {}} = args;
"Arguments:";
"  text: The text to be edited.";
"  prompt: The prompt displayed to the player to ask for input.";
"  commandchar: The character used to indicate an editor command vs text to be added.";
"  verb: A flag indicating whether or not this is verb code, which will add editor commands for compilation and commenting.";
"  extra: Extra information passed in, primarily for verb info to use with the compile command.";
if (typeof(text) == STR)
text = {text};
elseif (typeof(text) != LIST)
return raise(E_TYPE, "Invalid datatype");
endif
this:log_last_edit(player, task_id());
state = $edit_state:new(text, verb, extra);
"NOTE: The waif is created AND destroyed in-verb. It is NOT persistant!";
player:tell(prompt);
if (state.verb && state.extra)
verb_name = tostr($string_utils:nn(state.extra[1][1]), ":", state.extra[1][2]);
player:tell("Edytujesz teraz ", verb_name, ".");
state.verb_name = verb_name;
endif
state.ins = length(state.text) + 1;
player:tell("Punkt wstawiania jest przed linia ", state.ins, ".");
if (this:get_option("expert") == 0)
player:tell();
player:tell("Wpisz '", commandchar, "help' by uzyskac pomoc, '", commandchar, "abort' by porzucic.");
endif
while loop (1)
try
if (!player:is_listening())
return;
endif
cont = 1;
(!this:get_option("no_line_notifies")) && player:tell("  >");
line = read(player);
if (typeof(line) != STR)
return state.text;
endif
if (line == "@abort")
player:tell(">> Polecenie przerwane <<");
kill_task(task_id());
elseif (line == "..")
line = ".";
elseif (line == ".")
line = this:get_option("cmd_char") + "done";
endif
if (`line[1] ! ANY' == commandchar)
cmd = $string_utils:explode(line[2..$]);
if ((commandchar == ".") && (!cmd))
line = this:get_option("cmd_char") + "done";
elseif (!cmd)
player:tell("Musisz podac polecenie. (", commandchar, "help - pomoc.)");
continue;
endif
state.command = cmd[1];
state.arg = cmd[2..$];
if (state.command in {"insert", "ins", "inse", "inser", "wstaw"})
this:cmd_insert(state);
elseif (state.command in {"paste", "load", "wklej"})
this:cmd_load(state);
elseif (state.command in {"copy", "save", "kopiuj"})
this:cmd_save(state);
elseif (state.command in {"pass", "przekaz"})
this:cmd_pass(state);
elseif (state.command in {"reload", "rehash", "przeladuj"})
return this:cmd_reload(@args, state);
elseif (state.command in {"change", "changeline", "zmien"})
this:cmd_changeline(state);
elseif (state.command in {"replace", "repl", "re", "zamien"})
this:cmd_replace(state);
elseif (state.command in {"find", "search", "GREP", "f", "s", "znajdz", "szukaj"})
this:cmd_grep(state);
elseif (state.command in {"done", "quit", "q", "koniec"})
if (typeof(ret = this:cmd_quit(state)) == ERR)
continue;
else
return state.text;
endif
elseif (state.command in {"abort", "abandon", "q!", "przerwij"})
player:tell(">> Polecenie przerwane <<");
kill_task(task_id());
elseif ((state.verb && state.extra) && (state.command in {"what", "verb", "co"}))
player:tell("Obecnie edytujesz: ", state.extra[1][1]:nn(), ":", state.extra[1][2], ".");
elseif ((state.verb && state.extra) && (state.command in {"compile", "w", "send", "kompiluj"}))
{object, verbname} = state.extra[1];
program = this:program_verb(object, verbname, state);
elseif (state.verb && (state.command[1] == "/"))
"Assume they want to make a verb comment.";
line = ("\"" + line[3..$]) + "\";";
cont = 0;
elseif (state.command in {"import", "importuj"})
this:cmd_paste_letter(state);
elseif (state.command in {"set", "ustaw"})
this:options($string_utils:from_list(state.arg, " "));
elseif (state.command in {"del", "dele", "delet", "delete", "erase", "rm", "usun"})
this:cmd_delete(state);
elseif (state.command in {"list", "l", "view", "p", "pokaz"})
this:cmd_list(state);
elseif (state.verb && (state.command in {"comment", "commentify", "komentuj"}))
this:cmd_commentify(state);
elseif (state.verb && (state.command in {"uncomment", "uncommentify", "odkomentuj"}))
this:cmd_uncommentify(state);
elseif (state.command in {"spellcheck", "spell", "pisownia"})
state.text = $spell:interactive_spellcheck(state.text);
player:tell("Sprawdzanie pisowni zakonczone.");
elseif (state.command in {"count", "policz"})
this:cmd_count(state);
elseif (state.verb && (state.command in {"tb", "jtb"}))
this:cmd_traceback(state);
elseif (state.verb && (state.command in {"ptb", "print_traceback"}))
this:cmd_print_traceback(state);
elseif (state.verb && (state.command in {"local", "localedit", "lokalnie"}))
this:cmd_localedit(state);
elseif (state.command in {"format", "form", "formatuj"})
this:cmd_format(state);
elseif (state.command in {"help", "?", "pomoc"})
this:cmd_help(state);
elseif (state.command in {"clipboard", "saved", "clip", "schowek"})
this:cmd_show_clipboard(state);
else
player:tell("Nieznane polecenie. (", commandchar, "help - pomoc.)");
endif
if (cont != 0)
continue;
endif
endif
this:do_add_line(state, line);
except error (ANY)
player:tell("Cos poszlo nie tak...");
player:tell(toliteral(error));
break;
continue;
endtry
endwhile
.
#122:1
{arg, maxrange, insertion} = args;
if (typeof(arg) == LIST)
arg = $string_utils:from_list(arg, " ");
endif
range = {0, 0};
explode_by = {"..", " ", "-", "+"};
exploded_by = 0;
for x in (explode_by)
expl = $string_utils:explode(arg, x);
if (length(expl) > 1)
exploded_by = x;
break;
endif
endfor
if (length(expl) > 2)
return tostr("Junk at end of command: ", $string_utils:from_list(expl[3..$], " "), ".");
elseif (length(expl) == 1)
if ((single = expl[1]) == "$")
range = {maxrange, maxrange};
elseif (single == "^")
range = {insertion, insertion};
elseif ((toint(single) > 0) && (toint(single) <= maxrange))
range = {toint(single), toint(single)};
endif
else
for x in (expl)
if (x == "$")
line = maxrange;
elseif (x == "^")
line = insertion;
elseif (!$string_utils:is_numeric(x))
return tostr("Garbled Range: ", arg, " - should be integers");
elseif ((toint(x) <= 0) || (toint(x) > maxrange))
return tostr("Lines range from 1 to ", maxrange, ".");
else
line = toint(x);
endif
range[x in expl] = line;
endfor
endif
if (exploded_by == "+")
increment_line = range[1] + range[2];
range = {increment_line, increment_line};
endif
if (range[1] > range[2])
return tostr("Garbled Range: ", range[1], " greater than ", range[2], ". Put smallest index first.");
elseif (0 in range)
return tostr("Garbled Range: ", arg);
endif
return range;
.
