":check_player_request(name [,email [,connection]])";
" sprawdza, czy prosba o gracza i adres email sa poprawne;";
" zwraca pusty string, jesli sa poprawne, w przeciwnym razie string mowiacy dlaczego nie.";
" Wynik zaczyna sie od - jesli jest to sytuacja typu 'wyslij email, nie probuj ponownie'.";
":check_reregistration(who, email, connection)";
"  Poniewaz name jest ignorowane, sprawdzamy tylko czesci 'email' i uzywamy pierwszego argumentu";
"  dla ponownie rejestrujacego sie gracza.";
if (!caller_perms().wizard)
return E_PERM;
"accesses registration information -- wiz only";
endif
name = args[1];
if (verb == "check_reregistration")
"don't check player name";
elseif (!name)
return "Puste imie nie jest dozwolone.";
elseif (name == "<>")
return "Imiona z nawiasami ostrymi nie sa dozwolone.";
elseif (index(name, " "))
return "Imiona ze spacjami nie sa dozwolone. Uzyj myslnikow lub podkreslen.";
elseif (match(name, "^<.*>$"))
return tostr("Sprobuj uzyc ", name[2..$ - 1], " zamiast ", name, ".");
elseif ($player_db.frozen)
return "Nowi gracze nie moga byc obecnie tworzeni, sprobuj ponownie pozniej.";
elseif (!$player_db:available(name))
return ("Imie '" + name) + "' jest niedostepne.";
elseif ($login:_match_player(name) != $failed_match)
return ("Imie '" + name) + "' wyglada na niedostepne.";
endif
if (length(args) == 1)
"no email address supplied.";
return "";
endif
address = args[2];
addrargs = (verb == "check_reregistration") ? {name} | {};
if ($registration_db:suspicious_address(address, @addrargs))
return "-Istnieje juz postac z tym samym lub podobnym adresem email.";
endif
if (reason = $network:invalid_email_address(address))
return reason + ".";
endif
parsed = $network:parse_address(address);
if ($registration_db:suspicious_userid(parsed[1]))
return tostr("-Automatyczna rejestracja z konta o nazwie ", parsed[1], " nie jest dozwolona.");
endif
connection = (length(args) > 2) ? args[3] | parsed[2];
check_connection = $wiz_utils.registration_domain_restricted && (verb == "check_player_request");
if ((connection[max($ - 2, 1)..$] == ".uk") && (parsed[2][1..3] == "uk."))
return tostr("Adresy musza byc w formie internetowej. Sprobuj ", parsed[1], "@", $string_utils:from_list($list_utils:reverse($string_utils:explode(parsed[2], ".")), "."), ".");
elseif (check_connection && match(connection, "^[0-9.]+$"))
"Allow reregistration from various things we wouldn't allow registration from.  Let them register to their yahoo acct...";
return "-System nie moze rozpoznac nazwy systemu, z ktorego jestes polaczony.";
elseif (check_connection && ((a = $network:local_domain(connection)) != (b = $network:local_domain(parsed[2]))))
return tostr("-Polaczenie pochodzi z '", a, "', ale adres email to '", b, "'; wyglada na to, ze to nie to samo miejsce.");
elseif ((verb == "check_player_request") && $login:spooflisted(parsed[2]))
return tostr("-Automatyczna rejestracja nie jest dozwolona z ", parsed[2], ".");
endif
return "";
.
