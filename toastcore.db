2
@copy   -- kopiowanie czasownika z jednego obiektu na drugi
2

2
.program/@program -- wprowadzanie programu dla czasownika
2
@list -- wypisywanie listingu programu czasownika
2
@edit -- edycja kodu czasownika
2

2
@show     -- przegladanie wszystkich szczegolow obiektu, wlasciwosci lub czasownika
2
@parents  -- listowanie przodkow obiektu
2
@kids     -- listowanie dzieci obiektu
2
@contents -- listowanie zawartosci obiektu
2
@chmod    -- zmiana uprawnien obiektu, wlasciwosci lub czasownika
2
@chparent -- zmiana rodzica obiektu
2
@rename   -- zmiana nazwy czasownika lub obiektu
2

2
eval -- wykonywanie instrukcji i wyrazen MOO bez pisania czasownika
