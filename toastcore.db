if (typeof(ok) != LIST)
return player:notify(fail_msg);
endif
allmsgs = length($seq_utils:tolist(@ok));
count = missed = 0;
for position in ($list_utils:reverse($list_utils:range(allmsgs)))
time = time() + 60;
