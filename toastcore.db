#40:50
"Skladnia: @quicksend <odbiorca(y)> [subj=<tekst>] [<wiadomosc>]";
"Wysyla odbiorcy(om) szybka wiadomosc, bez konicznosci wchodzenia do pokoju poczty. Jesli jest wiecej niz jeden odbiorca, umiesc ich wszystkich w cudzyslowach. Jesli temat zawiera spacje, umiesc go w cudzyslowach.";
"By umiescic zlamania linii w wiadomosci, uzyj daszka (^).";
"Jesli nie podano wiadomosci, poprosi o linie wiadomosci.";
"Przyklady:";
"@quicksend Alice subj=\"Wonderland is neat!\" Have you checked out the Wonderland scenario yet? I think you'd like it!";
"@quicksend \"Ethel Fred\" Have you seen Lucy around?^--Ricky";
set_task_perms($object_utils:isa(player, $guest) ? player.owner | player);
if (!args)
player:notify(tostr("Uzycie: ", verb, " <odbiorca(y)> [subj=<tekst>] [<wiadomosc>]"));
return E_INVARG;
elseif (this != player)
player:notify(tostr("Nie mozesz uzyc cudzego czasownika @quicksend."));
return E_PERM;
elseif (!(recipients = $mail_editor:parse_recipients({}, $string_utils:explode(args[1]))))
return;
else
if ((length(args) > 1) && ((eq = index(args[2], "=")) && ((index("subject", args[2][1..eq - 1]) == 1) || (index("temat", args[2][1..eq - 1]) == 1))))
subject = $string_utils:trim(args[2][eq + 1..$]);
ws = $string_utils:word_start(argstr);
argstr = argstr[1..ws[1][2]] + argstr[ws[2][2] + 1..$];
args = listdelete(args, 2);
else
subject = "";
endif
if (length(args) > 1)
unbroken = argstr[(argstr[1] == "\"") ? length(args[1]) + 4 | (length(args[1]) + 2)..$] + "^";
message = {};
while (unbroken)
if (i = index(unbroken, "^"))
message = {@message, unbroken[1..i - 1]};
endif
unbroken = unbroken[i + 1..$];
endwhile
else
if (!(subject || player:mail_option("nosubject")))
player:notify("Temat:");
subject = $command_utils:read();
endif
player:notify("Wpisz linie wiadomosci:");
message = $command_utils:read_lines_escape((active = player in $mail_editor.active) ? {} | {"@edit"}, {tostr("Piszesz wiadomosc do ", $mail_agent:name_list(@recipients), "."), @active ? {} | {"Wpisz `@edit', by przejsc do edytora poczty."}});
if (typeof(message) == ERR)
player:notify(tostr(message));
return;
elseif (message[1] == "@edit")
$mail_editor:invoke(1, verb, recipients, subject, {}, message[2]);
return;
elseif (!(message[2] || subject))
player:notify("Pusta wiadomosc nie zostala wyslana.");
return;
endif
message = message[2];
endif
result = $mail_agent:send_message(this, recipients, subject, message);
if (result && result[1])
player:notify(tostr("Wiadomosc wyslana do ", $mail_agent:name_list(@listdelete(result, 1)), "."));
else
player:notify("Wiadomosc nie zostala wyslana.");
endif
endif
.
