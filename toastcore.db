lctime = ctime(time() - connected_seconds(u));
where = $string_utils:connection_hostname(connection_name(u));
else
lctime = ctime(u.last_connect_time);
where = u.last_connect_place;
endif
u3 = {tostr(pref, su:nn(u)), lctime[5..10] + lctime[20..24]};
