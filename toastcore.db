endif
else
"...kept, unkept...";
if (c < length(string))
return tostr("Nieoczekiwane znaki po `", keywd, ":'");
elseif ((!(seq = caller:(keywd + "_msg_seq")(seq))) && (strnum == 1))
return tostr("%f %<has> zadnych wiadomosci (", keywd, ").");
endif
endif
