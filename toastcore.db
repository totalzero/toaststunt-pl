player:tell("Laczna liczba bajtow uzytych w nowych tworach: ", total, ".", nunmeasured ? tostr(" Znaleziono lacznie ", nunmeasured, " ", $polish_utils:count(nunmeasured, "obiekt", "obiekty", "obiektow"), " bez wlasciwosci .object_size. To uniemozliwi dalsze budowanie.") | "");
