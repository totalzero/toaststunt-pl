player:notify(tostr("                    Wywolane przez...  ", su:left(valid(sprogger) ? sprogger.name | tostr("Martwy ", sprogger), 19), "  ", svloc, ":", svname, (sthis != svloc) ? tostr(" [", sthis, "]") | "", " (", slineno, ")"));
endfor
