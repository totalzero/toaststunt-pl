"Dla zwyklego gracza pokazuje wszystkie zadania czekajace w twojej kolejce, zwlaszcza sforkowane lub zawieszone. Wizard zobaczy zadania wszystkich graczy, chyba ze podano opcjonalny argument. @forked-v*erbose pokaze pelny stos callers() dla kazdego zadania, ktore zostalo zawieszone (a nie jest swiezym forkiem).";
"Druga forma jest uzywana tylko przez wizardow i podaje wszystkie zadania nalezace do postaci majacych .wizard=1. Przydatne do znalezienia zadania, ktore moze trafic do przypadkowej kolejki przez $wiz_utils:random_wizard. Albo do znalezienia czasownikow, ktore dzialaja z uprawnieniami wizarda, a nie powinny.";
set_task_perms(player);
verbose = $code_utils:verbname_match("@forked-v*erbose", verb);
if (!dobjstr)
tasks = queued_tasks();
elseif ((dobjstr == "all wizards") && player.wizard)
tasks = {};
for t in (queued_tasks())
if (valid(t[5]) && t[5].wizard)
tasks = {@tasks, t};
endif
$command_utils:suspend_if_needed(1);
endfor
elseif ($command_utils:player_match_result(dobj = $string_utils:match_player(dobjstr), dobjstr)[1])
return;
elseif (typeof(tasks = $wiz_utils:queued_tasks(dobj)) != LIST)
player:notify(tostr(verb, " ", dobj.name, "(", dobj, "):  ", tasks));
return;
endif
if (tasks)
su = $string_utils;
player:notify("ID kolejki  Czas startu           Wlasciciel    {Rozmiar} Czasownik (Linia) [To]");
player:notify("----------  -----------           ----------    ------------------------------");
now = time();
for task in (tasks)
$command_utils:suspend_if_needed(0);
{q_id, start, nu, nu2, owner, vloc, vname, lineno, this, ?size = 0} = task;
if (typeof(start) == STR)
time = start;
else
time = (start >= now) ? ctime(start)[5..24] | su:left((start == -1) ? "Odczytywanie danych ..." | tostr(now - start, " sekund temu..."), 20);
endif
owner_name = valid(owner) ? owner.name | tostr("Martwy ", owner);
player:notify(tostr(su:left(tostr(q_id), 10), "  ", time, "  ", su:left(owner_name, 12), "  {", $building_utils:size_string(size), "} ", vloc, ":", vname, " (", lineno, ")", (this != vloc) ? tostr(" [", this, "]") | ""));
