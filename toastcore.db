2
encode_binary("~foo")                     =>  "~7Efoo"
2
encode_binary({"foo", 10}, {"bar", 13})   =>  "foo~0Abar~0D"
2
encode_binary("foo", 10, "bar", 13)       =>  "foo~0Abar~0D"
