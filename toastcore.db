return E_PERM;
endif
"No need to worry about orphans or contents, as recycle() will handle all of that for us.";
set_task_perms(who);
if (valid(object))
recycle(object);
endif
if (!valid(parent))
"We're done here. All we wanted to do was recycle with who's permissions.";
return 1;
else
recreate(object, parent, who);
object.name = "";
object.r = 0;
object.f = 0;
object.w = 0;
return 1;
endif
