player:tell($string_utils:nn(what), " przy ostatnim pomiarze mial ", $string_utils:group_number(what.object_size[1]), " bajtow.  By zmniejszyc lag powodowany przez wielokrotne ponowne mierzenie duzych obiektow przez wielu graczy, nie mozesz zmierzyc tego obiektu.");
