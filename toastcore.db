"...use integers to determine a four-char string...";
factor = 1000;
threshold = {{1000, "B"}, {1000000, "K"}, {1000000000, "M"}};
if (!size)
return " ???";
elseif ((size < 0) || (size > threshold[$][1]))
if ((size < 0) || (size > $maxint))
