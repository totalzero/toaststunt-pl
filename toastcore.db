if (caller_perms().wizard)
pass(@args);
`delete_property(this, "mail_name_db") ! E_PROPNF';
`delete_verb(this, "do_command") ! E_VERBNF';
$server["core_history"] = {{$network.MOO_name, server_version(), time()}, @$server["core_history"]};
$wiz_utils.shutdown_message = "";
$server["shutdown_time"] = 0;
$server_options.dump_interval = 3600;
$wiz_utils.gripe_recipients = {player};
$class_registry = {{"generics", "Generyczne obiekty przeznaczone jako rodzice nowych obiektow", {$room, $exit, $thing, $note, $letter, $container, $root_class, $player, $prog, $wiz, $generic_editor, $mail_recipient, $mail_agent}, $builder}, {"utilities", "Obiekty zawierajace przydatne czasowniki ogolnego przeznaczenia", {@children($generic_utils), $shapes}, $prog}, {"server", "Obiekty zawierajace funkcjonalnosc wplywajaca na serwer.", {$telnet, $server_options, $http}, $wiz}, {"prototypes", "Obiekty zawierajace czasowniki, ktore moga byc wywolywane na odpowiadajacych im typach.", children($proto), $prog}};
for v in ({"do_login_command", "server_started"})
c = {};
for i in (verb_code(this, v))
c = {@c, strsub(i, "$local.login", "$login")};
endfor
set_verb_code(#0, v, c);
endfor
endif
