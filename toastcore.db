"make_exit(spec, source, dest[, use-$recycler-pool [, kind]])";
"";
"Uses $recycler by default; supplying fourth arg as 0 suppresses this.";
"Optional 5th arg gives a parent for the object to be created";
"(i.e., distinct from $exit)";
"Returns the object number as a list if successful, 0 if not.";
set_task_perms(caller_perms());
{spec, source, dest, ?use_recycler, ?exit_kind = $exit} = args;
exit = player:_create(exit_kind);
if (typeof(exit) == ERR)
player:notify(tostr("Nie mozna utworzyc nowego wyjscia jako dziecka ", $string_utils:nn(exit_kind), ": ", exit, ".  Zobacz `help @build-options' - opisano tam sposob okreslania rodzaju wyjscia tworzonego przez to polecenie."));
return;
endif
for f in ($string_utils:char_list(player:build_option("create_flags") || ""))
exit.(f) = 1;
endfor
$building_utils:set_names(exit, spec);
exit.source = source;
exit.dest = dest;
source_ok = source:add_exit(exit);
dest_ok = dest:add_entrance(exit);
move(exit, $nothing);
via = $string_utils:from_value(setadd(exit.aliases, exit.name), 1);
if (source_ok)
player:tell("Utworzono wyjscie z ", source.name, " (", source, ") do ", dest.name, " (", dest, ") przez ", via, ", o numerze ", exit, ".");
if (!dest_ok)
player:tell("Nie udalo sie jednak dodac ", exit, " jako prawidlowego wejscia do ", dest.name, ".  Byc moze bedziesz musial poprosic wlasciciela, ", dest.owner.name, ", by dodal je za ciebie.");
endif
return {exit};
elseif (dest_ok)
player:tell("Utworzono wyjscie do ", dest.name, " (", dest, ") przez ", via, ", o numerze ", exit, ".  Nie udalo sie jednak dodac ", exit, " jako prawidlowego wyjscia z ", source.name, ".  Popros wlasciciela, ", source.owner.name, ", by dodal je za ciebie.");
return {exit};
