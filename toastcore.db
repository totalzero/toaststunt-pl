endif
day = week = month = ever = never = {};
a_day = (24 * 60) * 60;
a_week = 7 * a_day;
a_month = 30 * a_day;
now = time();
for x in (folks)
when = x.last_connect_time;
how_long = now - when;
if ((when == 0) || (when > now))
never = {@never, x};
elseif (how_long < a_day)
day = {@day, x};
elseif (how_long < a_week)
week = {@week, x};
elseif (how_long < a_month)
month = {@month, x};
else
ever = {@ever, x};
endif
endfor
for entry in ({{day, "ostatniego dnia"}, {week, "ostatniego tygodnia"}, {month, "ostatnich 30 dni"}, {ever, "zarejestrowanej historii"}})
if (entry[1])
player:tell("Gracze, ktorzy laczyli sie w ciagu ", entry[2], ":");
for x in (entry[1])
player:tell("  ", x.name, " -- ostatnie polaczenie: ", ctime(x.last_connect_time), ".");
endfor
endif
endfor
if (never)
