if (callers())
return;
endif
if (args[1] < #0)
"not logged in user.  probably should do something clever here involving Carrot's no-spam hack.  --yduJ";
"...'forget' that we already performed a name lookup on this connection...";
$login:delete_name_lookup(args[1]);
return;
endif
